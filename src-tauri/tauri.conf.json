{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PrivacyTextAssistant",
  "version": "0.1.0",
  "identifier": "com.privacytextassistant.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PrivacyTextAssistant",
        "width": 760,
        "height": 640,
        "minWidth": 640,
        "minHeight": 500,
        "resizable": false,
        "center": true,
        "alwaysOnTop": false,
        "visible": false,
        "decorations": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://api.openai.com; img-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "category": "Productivity",
    "shortDescription": "Privacy-first corporate writing assistant",
    "longDescription": "A Windows writing assistant that transforms selected text through the OpenAI API without telemetry.",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    }
  }
}
